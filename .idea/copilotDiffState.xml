onfronto di idee.&lt;/li&gt;&#10;          &lt;li&gt;Comunicazione chiara e argomentazione in pubblico.&lt;/li&gt;&#10;          &lt;li&gt;Empatia e intelligenza emotiva nei lavori di gruppo.&lt;/li&gt;&#10;          &lt;li&gt;Sensibilita storica e culturale applicata al presente.&lt;/li&gt;&#10;        &lt;/ul&gt;&#10;      &lt;/article&gt;&#10;&#10;      &lt;article class=&quot;card&quot;&gt;&#10;        &lt;h2&gt;Risultato personale&lt;/h2&gt;&#10;        &lt;p&gt;&#10;          Torno da questa esperienza con maggiore apertura mentale, consapevolezza personale e sicurezza nell'interazione&#10;          con gli altri. E un passaggio importante per il mio percorso di studio e di crescita.&#10;        &lt;/p&gt;&#10;      &lt;/article&gt;&#10;    &lt;/section&gt;&#10;&#10;    &lt;section id=&quot;foto&quot; class=&quot;card reveal&quot; aria-label=&quot;Galleria foto Grecia&quot;&gt;&#10;      &lt;h2&gt;Galleria foto&lt;/h2&gt;&#10;&#10;      &lt;div class=&quot;photo-grid&quot;&gt;&#10;        &lt;div class=&quot;photo-slot&quot;&gt;&#10;          &lt;img class=&quot;photo-preview&quot; src=&quot;immagini/grecia_4.jpeg&quot; alt=&quot;Atene e Acropoli&quot; /&gt;&#10;          &lt;span class=&quot;photo-help&quot;&gt;Atene / Acropoli&lt;/span&gt;&#10;        &lt;/div&gt;&#10;        &lt;div class=&quot;photo-slot&quot;&gt;&#10;          &lt;img class=&quot;photo-preview&quot; src=&quot;immagini/grecia_3.jpeg&quot; alt=&quot;Delfi&quot; /&gt;&#10;          &lt;span class=&quot;photo-help&quot;&gt;Delfi&lt;/span&gt;&#10;        &lt;/div&gt;&#10;        &lt;div class=&quot;photo-slot&quot;&gt;&#10;          &lt;img class=&quot;photo-preview&quot; src=&quot;immagini/delfi.jpeg&quot; alt=&quot;Epidauro&quot; /&gt;&#10;          &lt;span class=&quot;photo-help&quot;&gt;Epidauro&lt;/span&gt;&#10;        &lt;/div&gt;&#10;        &lt;div class=&quot;photo-slot&quot;&gt;&#10;          &lt;img class=&quot;photo-preview&quot; src=&quot;immagini/grecia_2.jpeg&quot; alt=&quot;Momenti con la classe&quot; /&gt;&#10;          &lt;span class=&quot;photo-help&quot;&gt;Momenti con la classe&lt;/span&gt;&#10;        &lt;/div&gt;&#10;      &lt;/div&gt;&#10;    &lt;/section&gt;&#10;  &lt;/main&gt;&#10;&#10;  &lt;footer&gt;PCTO 2026 - Esperienza Grecia&lt;/footer&gt;&#10;&#10;  &lt;script src=&quot;scripts/pcto.js&quot;&gt;&lt;/script&gt;&#10;&lt;/body&gt;&#10;&lt;/html&gt;&#10;" />
